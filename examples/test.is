let double(x) {
    x * 2
}

let add(a, b) {
    a + b
}

let fib(n) {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

let ping(n) {
    if n == 0 { true } else { pong(n - 1) }
}

let pong(n) {
    if n == 0 { false } else { ping(n - 1) }
}

let multiblock(x) {
    let a = x + 1
    let b = a * 2
    b - 1
}

